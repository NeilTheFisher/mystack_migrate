{
  "name": "@neilthefisher/my-bts-stack-migrate",
  "version": "1.0.0",
  "private": false,
  "bin": {
    "my-bts-stack-migrate": "migrate_neil_stack.ts"
  },
  "files": [
    "migrate_neil_stack.ts",
    "dist",
    "files/*"
  ],
  "scripts": {
    "build": "bun build --target=bun --minify --outdir dist migrate_neil_stack.ts",
    "build_dev": "bun build --target=bun --minify --sourcemap=inline --outdir dist migrate_neil_stack.ts",
    "fmt": "bun fmt.ts",
    "lint": "bun run --parallel lint:oxlint lint:biome lint:oxfmt",
    "lint:biome": "biome check --diagnostic-level=error",
    "lint:oxfmt": "oxfmt --threads=2 --check || (echo '\n\n\nRun `bun fmt` to fix formatting issues!\n\n\n'; exit 1)",
    "lint:oxlint": "oxlint --threads=2 --type-aware --type-check --quiet",
    "prepare": "husky",
    "publish": "bun publish --access public --dry-run",
    "start": "bun run build && bun dist/migrate_neil_stack.js",
    "update-deps": "bun update -i -r",
    "yeet": "git add . && git commit -m 'yeet' && git push"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.9",
    "@types/yargs": "^17.0.35",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,js,jsx,mjs}": [
      "oxfmt",
      "biome lint --only=noUnusedImports --fix",
      "oxlint --threads=2 --type-aware --type-check --quiet",
      "biome check --diagnostic-level=error --no-errors-on-unmatched"
    ]
  }
}
